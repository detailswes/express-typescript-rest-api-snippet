{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "outDir": "dist",
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["es2017"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"],
  "ts-node": {
    "files": true
  }
}
