NODE_ENV=development
PORT=5000

DB_URL=mongodb://localhost:27017/code-snippet-node

JWT_SECRET=replace-with-a-secret-at-least-32-characters-long

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=Code Snippet API

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

LOG_LEVEL=info

# Swagger UI at /api/docs (enabled in development; set false to disable)
SWAGGER_ENABLED=true
